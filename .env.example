# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pos_db"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Public URL used in QR codes (set to ngrok/LAN URL for phone testing)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Metabase (optional — enables the Metabase tab in /analytics)
# 1. docker compose up -d metabase  →  open http://localhost:4000
# 2. Connect database: host=postgres port=5432 db=pos_db user=postgres pass=postgres
# 3. Admin → Settings → Embedding → Enable → copy Secret key
# 4. Build a dashboard, get its numeric ID from the URL bar (/dashboard/1)
METABASE_SITE_URL="http://localhost:4000"
METABASE_SECRET_KEY=""
METABASE_DASHBOARD_ID=""
